{
  "name": "teste-tecnico-qa-api-dog",
  "version": "1.0.0",
  "description": "Testes automatizados para Dog API - Cypress",
  "main": "index.js",
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test": "cypress run --reporter mochawesome",
    "test:dog": "cypress run --spec 'cypress/e2e/dog-api/**/*.cy.js' --reporter mochawesome",
    "test:headed": "cypress run --headed --reporter mochawesome",
    "report": "mochawesome-report-generator mochawesomeReports/*.json"
  },
  "keywords": [
    "cypress",
    "api",
    "testing",
    "dog-api",
    "qa"
  ],
  "author": "QA Team",
  "license": "MIT",
  "devDependencies": {
    "cypress": "^13.6.0",
    "ajv": "^8.12.0",
    "mochawesome": "^7.1.3",
    "mochawesome-report-generator": "^6.2.0"
  }
}
